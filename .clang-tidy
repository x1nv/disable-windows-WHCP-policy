---
Checks: >
  -*,
  bugprone-*,
  google-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*,
  -modernize-use-trailing-return-type

WarningsAsErrors: "*"
HeaderFilterRegex: "^(src|include)/.*"

FormatStyle: file

CheckOptions:
  - key: readability-function-size.LineThreshold
    value: "40"

  - key: readability-function-size.StatementThreshold
    value: "80"
...
